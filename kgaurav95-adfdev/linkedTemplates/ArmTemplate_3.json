								{
									"name": "Switch",
									"type": "Switch",
									"dependsOn": [],
									"userProperties": [],
									"typeProperties": {
										"on": {
											"value": "@substring(item().name, add(lastIndexOf(item().name, '.'),1), 3)\n",
											"type": "Expression"
										},
										"cases": [
											{
												"value": "CaseCSV",
												"activities": [
													{
														"name": "Copy CSV TO ADLS GEN2",
														"type": "Copy",
														"dependsOn": [],
														"policy": {
															"timeout": "0.12:00:00",
															"retry": 0,
															"retryIntervalInSeconds": 30,
															"secureOutput": false,
															"secureInput": false
														},
