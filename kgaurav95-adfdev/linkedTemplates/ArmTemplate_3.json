					{
						"name": "FILTER_CSV_FILE_SEGREGATION",
						"type": "Filter",
						"dependsOn": [
							{
								"activity": "GET_METEDATA_FILE_SEGREGATION",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@activity('GET_METEDATA_FILE_SEGREGATION').output.childItems",
								"type": "Expression"
							},
							"condition": {
								"value": "@or(endswith(item().name, '.csv'), endswith(item().name, '.txt'))",
								"type": "Expression"
							}
						}
					},
					{
						"name": "ForEach",
						"type": "ForEach",
						"dependsOn": [
							{
								"activity": "FILTER_CSV_FILE_SEGREGATION",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
